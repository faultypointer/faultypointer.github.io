aster than Numpy in C\u003c/a\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"rust\" class=\"scroll-mt-8 group\"\u003e\n  Rust\n  \n    \u003ca href=\"#rust\"\n        class=\"no-underline hidden opacity-50 hover:opacity-100 !text-inherit group-hover:inline-block\"\n        aria-hidden=\"true\" title=\"Link to this heading\" tabindex=\"-1\"\u003e\n        \u003csvg\n  xmlns=\"http://www.w3.org/2000/svg\"\n  width=\"16\"\n  height=\"16\"\n  fill=\"none\"\n  stroke=\"currentColor\"\n  stroke-linecap=\"round\"\n  stroke-linejoin=\"round\"\n  stroke-width=\"2\"\n  class=\"lucide lucide-link w-4 h-4 block\"\n  viewBox=\"0 0 24 24\"\n\u003e\n  \u003cpath d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\" /\u003e\n  \u003cpath d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\" /\u003e\n\u003c/svg\u003e\n\n    \u003c/a\u003e\n  \n\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ca href=\"https://www.joshmcguigan.com/blog/understanding-serde/\"\u003eUnderstanding Serde\u003c/a\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"django\" class=\"scroll-mt-8 group\"\u003e\n  Django\n  \n    \u003ca href=\"#django\"\n        class=\"no-underline hidden opacity-50 hover:opacity-100 !text-inherit group-hover:inline-block\"\n        aria-hidden=\"true\" title=\"Link to this heading\" tabindex=\"-1\"\u003e\n        \u003csvg\n  xmlns=\"http://www.w3.org/2000/svg\"\n  width=\"16\"\n  height=\"16\"\n  fill=\"none\"\n  stroke=\"currentColor\"\n  stroke-linecap=\"round\"\n  stroke-linejoin=\"round\"\n  stroke-width=\"2\"\n  class=\"lucide lucide-link w-4 h-4 block\"\n  viewBox=\"0 0 24 24\"\n\u003e\n  \u003cpath d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\" /\u003e\n  \u003cpath d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\" /\u003e\n\u003c/svg\u003e\n\n    \u003c/a\u003e\n  \n\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ca href=\"https://www.mattlayman.com/understand-django/\"\u003eUnderstanding Dja