---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Get all published posts
const allPosts = await getCollection("posts", ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Get recent posts (last 5)
const recentPosts = sortedPosts.slice(0, 5);

// Get series metadata
const allSeriesMeta = await getCollection("series-meta", ({ data }) => {
  return data.draft !== true;
});

// Get all series parts to calculate update dates
const allSeriesParts = await getCollection("series", ({ data }) => {
  return data.draft !== true;
});

// Helper to extract series slug
function getSeriesSlug(id: string): string {
  return id.replace(/\.(md|mdx)$/, "").split('/')[0];
}

// Create series list
const recentSeries = allSeriesMeta
  .map((meta) => {
    const slug = getSeriesSlug(meta.id);
    const parts = allSeriesParts.filter(part =>
      getSeriesSlug(part.id) === slug
    );
    
    const lastUpdate = parts.length > 0
      ? parts.reduce((latest, part) => 
          part.data.date > latest ? part.data.date : latest, 
          parts[0].data.date
        )
      : new Date();
    
    return {
      slug,
      title: meta.data.title,
      description: meta.data.description,
      partCount: parts.length,
      lastUpdate,
    };
  })
  .sort((a, b) => b.lastUpdate.valueOf() - a.lastUpdate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="The Fault In My Writings">
  <div class="home">
    <section class="hero">
      <h1>The Fault In My Writings.</h1>
      <p class="subtitle">
        Exploring programming, low-level systems, and the occasional story.
      </p>
    </section>

    {recentSeries.length > 0 && (
      <section class="recent-series">
        <div class="section-header">
          <h2>Recent Series</h2>
          <a href="/series/" class="view-all">View all →</a>
        </div>

        <div class="series-grid">
          {recentSeries.map((series) => {
            const formattedDate = series.lastUpdate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
            });
            
            return (
              <article class="series-card">
                <h3>
                  <a href={`/series/${series.slug}`}>{series.title}</a>
                </h3>
                <p class="description">{series.description}</p>
                <div class="series-footer">
                  <span class="part-count">{series.partCount} {series.partCount === 1 ? 'part' : 'parts'}</span>
                  <time>Updated {formattedDate}</time>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )}

    <section class="recent-posts">
      <div class="section-header">
        <h2>Recent Posts</h2>
        <a href="/posts/" class="view-all">View all →</a>
      </div>

      <div class="posts-grid">
        {recentPosts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          
          return (
            <article class="post-card">
              <h3>
                <a href={`/posts/${post.slug}`}>{post.data.title}</a>
              </h3>
              <p class="description">{post.data.description}</p>
              <div class="post-footer">
                <time datetime={post.data.date.toISOString()}>
                  {formattedDate}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
