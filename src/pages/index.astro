    margin-bottom: 1rem;
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-footer time {
    color: #64748b;
    font-size: 0.875rem;
  }

