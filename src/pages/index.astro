---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Get all published posts, sorted by date (newest first)
const allPosts = await getCollection("posts", ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Get recent posts (last 10)
const recentPosts = sortedPosts.slice(0, 10);
---

<BaseLayout title="The Fault In My Writings">
  <div class="home">
    <section class="hero">
      <h1>The Fault In My Writings.</h1>
      <p class="subtitle">
        Exploring programming, low-level systems, and the occasional story.
      </p>
    </section>

    <section class="recent-posts">
      <div class="section-header">
        <h2>Recent Posts</h2>
        <a href="/posts/" class="view-all">View all →</a>
      </div>

      <div class="posts-grid">
        {recentPosts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          
          return (
            <article class="post-card">
              {post.data.series && (
                <div class="series-indicator">
                  Part {post.data.series.part} · {post.data.series.name}
                </div>
              )}
              <h3>
                <a href={`/posts/${post.slug}`}>{post.data.title}</a>
              </h3>
              <p class="description">{post.data.description}</p>
              <div class="post-footer">
                <time datetime={post.data.date.toISOString()}>
                  {formattedDate}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    max-width: 900px;
    margin: 0 auto;
  }

  .hero {
    margin-bottom: 4rem;
    text-align: left;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    color: #1e293b;
  }

  .subtitle {
    font-size: 1.25rem;
    color: #64748b;
    line-height: 1.6;
    max-width: 600px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    font-size: 1.875rem;
    font-weight: 600;
    color: #1e293b;
  }

  .view-all {
    color: #4f46e5;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: color 0.15s ease;
  }

  .view-all:hover {
    color: #312e81;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    padding: 1.5rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(79, 70, 229, 0.1);
    background: rgba(255, 255, 255, 0.5);
    transition: all 0.2s ease;
  }

  .post-card:hover {
    border-color: rgba(79, 70, 229, 0.25);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.08);
    transform: translateY(-2px);
  }

  .series-indicator {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    margin-bottom: 0.75rem;
    background: rgba(99, 102, 241, 0.08);
    color: #4f46e5;
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 500;
  }

  .post-card h3 {
    margin: 0 0 0.75rem 0;
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .post-card h3 a {
    color: #1e293b;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .post-card h3 a:hover {
    color: #4f46e5;
  }

  .description {
    color: #475569;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-footer time {
    color: #64748b;
    font-size: 0.875rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8125rem;
    color: #4f46e5;
    background: rgba(99, 102, 241, 0.06);
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .subtitle {
      font-size: 1.0625rem;
    }

    .section-header h2 {
      font-size: 1.5rem;
    }

    .post-card {
      padding: 1.25rem;
    }

    .post-card h3 {
      font-size: 1.125rem;
    }
  }
</style>