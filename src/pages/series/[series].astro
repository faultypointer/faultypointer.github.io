---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const allSeriesMeta = await getCollection("series-meta");
  
  return allSeriesMeta.map((meta) => {
      const seriesSlug = meta.id.replace(/\.(md|mdx)$/, "");    return {
      params: { series: seriesSlug },
      props: { meta },
    };
  });
}

const { meta } = Astro.props;
const seriesSlug = meta.id.replace(/\.(md|mdx)$/, "");
// Get all parts for this series
const allParts = await getCollection("series");
const seriesParts = allParts
  .filter(part => part.id.startsWith(`${seriesSlug}/`))
  .filter(part => !part.data.draft)
  .sort((a, b) => a.data.part - b.data.part);

const lastUpdate = seriesParts.length > 0
  ? seriesParts.reduce((latest, part) => 
      part.data.date > latest ? part.data.date : latest, 
      seriesParts[0].data.date
    )
  : new Date();

const formattedLastUpdate = lastUpdate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Render the series description content
const { Content } = await meta.render();
---

<BaseLayout 
  title={`${meta.data.title} | The Fault In My Writings`}
  description={meta.data.description}
>
  <div class="series-detail">
    <header class="series-header">
      <div class="breadcrumb">
        <a href="/series">Series</a>
        <span class="separator">/</span>
        <span>{meta.data.title}</span>
      </div>
      
      <h1>{meta.data.title}</h1>
      <p class="description">{meta.data.description}</p>
      
      <div class="series-info">
        <span class="part-count">{seriesParts.length} {seriesParts.length === 1 ? 'part' : 'parts'}</span>
        <span class="separator">·</span>
        <time>Last updated {formattedLastUpdate}</time>
      </div>

      {meta.data.tags.length > 0 && (
        <div class="tags">
          {meta.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    {/* Series overview content from _meta.md */}
    <section class="series-overview">
      <Content />
    </section>

    <section class="parts-list">
      <h2>All Parts</h2>
      <ol class="parts">
        {seriesParts.map((part) => {
          const partSlug = part.id.split('/')[1].replace(/\.(md|mdx)$/, '');
          const formattedDate = part.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          
          return (
            <li class="part-item">
              <div class="part-number">Part {part.data.part}</div>
              <div class="part-content">
                <h3>
                  <a href={`/series/${seriesSlug}/${partSlug}`}>
                    {part.data.title}
                  </a>
                </h3>
                <p class="part-description">{part.data.description}</p>
                <time datetime={part.data.date.toISOString()}>
                  {formattedDate}
                </time>
              </div>
            </li>
          );
        })}
      </ol>
    </section>
  </div>
</BaseLayout>

<style>
  .series-detail {
    max-width: 800px;
    margin: 0 auto;
  }

  .series-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(79, 70, 229, 0.15);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
    color: #64748b;
  }

  .breadcrumb a {
    color: #4f46e5;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: #312e81;
  }

  .breadcrumb .separator {
    color: #cbd5e1;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    color: #1e293b;
  }

  .description {
    font-size: 1.125rem;
    color: #475569;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .series-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    font-size: 0.9375rem;
    margin-bottom: 1rem;
  }

  .part-count {
    font-weight: 600;
    color: #4f46e5;
  }

  .separator {
    color: #cbd5e1;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    padding: 0.375rem 0.75rem;
    background: rgba(99, 102, 241, 0.08);
    color: #4f46e5;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    text-decoration: none;
    font-weight: 500;
    transition: background-color 0.15s ease;
  }

  .tag:hover {
    background: rgba(99, 102, 241, 0.15);
  }

  .series-overview {
    margin-bottom: 3rem;
    padding: 2rem;
    background: rgba(248, 250, 252, 0.8);
    border-radius: 0.5rem;
    border: 1px solid rgba(79, 70, 229, 0.1);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #1e293b;
  }

  .series-overview :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .series-overview :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .series-overview :global(p) {
    margin-bottom: 1rem;
  }

  .series-overview :global(ul),
  .series-overview :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .series-overview :global(li) {
    margin-bottom: 0.5rem;
  }

  .parts-list h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: #1e293b;
  }

  .parts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .part-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(79, 70, 229, 0.1);
    background: rgba(255, 255, 255, 0.5);
    transition: all 0.2s ease;
  }

  .part-item:hover {
    border-color: rgba(79, 70, 229, 0.25);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.08);
    transform: translateY(-2px);
  }

  .part-number {
    font-size: 0.875rem;
    font-weight: 600;
    color: #4f46e5;
    background: rgba(99, 102, 241, 0.08);
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    height: fit-content;
    text-align: center;
  }

  .part-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .part-content h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .part-content h3 a {
    color: #1e293b;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .part-content h3 a:hover {
    color: #4f46e5;
  }

  .part-description {
    color: #475569;
    line-height: 1.6;
    margin: 0;
  }

  .part-content time {
    color: #64748b;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .part-item {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .part-content h3 {
      font-size: 1.125rem;
    }

    .series-overview {
      padding: 1.5rem;
    }
  }
</style>