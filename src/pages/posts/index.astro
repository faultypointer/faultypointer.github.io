---
// src/pages/posts/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Get all published posts
const allPosts = await getCollection("posts", ({ data }) => {
  return data.draft !== true;
});

// Sort by date (newest first)
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group posts by year
const postsByYear = sortedPosts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof sortedPosts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));

// Get all unique tags
const allTags = [...new Set(sortedPosts.flatMap(post => post.data.tags || []))].sort();
---

<BaseLayout 
  title="All Posts | The Fault In My Writings"
  description="Browse all posts on programming, low-level systems, and more."
>
  <div class="posts-page">
    <header class="page-header">
      <h1>All Posts</h1>
      <p class="subtitle">{sortedPosts.length} {sortedPosts.length === 1 ? 'post' : 'posts'} and counting</p>
    </header>

    {allTags.length > 0 && (
      <section class="tags-filter">
        <h2>Filter by tag:</h2>
        <div class="tags-list">
          {allTags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      </section>
    )}

    <section class="posts-timeline">
      {years.map((year) => (
        <div class="year-group">
          <h2 class="year-heading">{year}</h2>
          <div class="posts-list">
            {postsByYear[Number(year)].map((post) => {
              const formattedDate = post.data.date.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
              });
              
              return (
                <article class="post-item">
                  <time datetime={post.data.date.toISOString()}>
                    {formattedDate}
                  </time>
                  <div class="post-info">
                    {post.data.series && (
                      <span class="series-badge">
                        Part {post.data.series.part}
                      </span>
                    )}
                    <h3>
                      <a href={`/posts/${post.slug}`}>{post.data.title}</a>
                    </h3>
                    <p class="description">{post.data.description}</p>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="tags">
                        {post.data.tags.map((tag) => (
                          <span class="tag">#{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .posts-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    color: #1e293b;
  }

  .subtitle {
    font-size: 1.125rem;
    color: #64748b;
  }

  .tags-filter {
    margin-bottom: 3rem;
    padding: 1.5rem;
    background: rgba(248, 250, 252, 0.8);
    border-radius: 0.5rem;
    border: 1px solid rgba(79, 70, 229, 0.1);
  }

  .tags-filter h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #475569;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags-list .tag {
    padding: 0.375rem 0.75rem;
    background: rgba(255, 255, 255, 0.8);
    color: #4f46e5;
    border: 1px solid rgba(79, 70, 229, 0.15);
    border-radius: 0.375rem;
    font-size: 0.875rem;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .tags-list .tag:hover {
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(79, 70, 229, 0.25);
  }

  .posts-timeline {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .year-group {
    position: relative;
  }

  .year-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid rgba(79, 70, 229, 0.15);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 1.25rem;
    border-radius: 0.5rem;
    transition: background-color 0.15s ease;
  }

  .post-item:hover {
    background: rgba(248, 250, 252, 0.6);
  }

  .post-item time {
    color: #64748b;
    font-size: 0.875rem;
    font-weight: 500;
    padding-top: 0.25rem;
  }

  .post-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .series-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: rgba(99, 102, 241, 0.08);
    color: #4f46e5;
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 500;
    width: fit-content;
  }

  .post-item h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .post-item h3 a {
    color: #1e293b;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .post-item h3 a:hover {
    color: #4f46e5;
  }

  .description {
    color: #475569;
    line-height: 1.6;
    font-size: 0.9375rem;
    margin: 0;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tags .tag {
    font-size: 0.8125rem;
    color: #4f46e5;
    background: rgba(99, 102, 241, 0.06);
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .post-item {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .post-item time {
      padding-top: 0;
    }

    .post-item h3 {
      font-size: 1.125rem;
    }
  }
</style>