---
interface Props {
  id?: string;
}

const { id } = Astro.props;
const noteId = id || `sn-${Math.random().toString(36).substr(2, 9)}`;
---

<label for={noteId} class="margin-toggle sidenote-number"></label>
<input type="checkbox" id={noteId} class="margin-toggle" />
<span class="sidenote">
  <slot />
</span>

<style>
  /* Hide the checkbox */
  .margin-toggle {
    display: none;
  }

  /* Sidenote number in the text */
  .sidenote-number {
    counter-increment: sidenote-counter;
  }

  .sidenote-number:after {
    content: counter(sidenote-counter);
    font-size: 0.75rem;
    position: relative;
    vertical-align: baseline;
    top: -0.5em;
    left: 0.1rem;
    color: #4f46e5;
    cursor: pointer;
  }

  /* The sidenote itself */
  .sidenote {
    float: right;
    clear: right;
    margin-right: -60%;
    width: 50%;
    margin-top: 0.3rem;
    margin-bottom: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    vertical-align: baseline;
    position: relative;
    color: #475569;
  }

  .sidenote:before {
    content: counter(sidenote-counter) " ";
    font-size: 0.75rem;
    position: relative;
    top: -0.5em;
    color: #4f46e5;
  }

  /* Mobile: sidenotes become toggleable footnotes */
  @media (max-width: 1024px) {
    .sidenote-number:after {
      cursor: pointer;
    }

    .sidenote {
      display: none;
      float: left;
      clear: both;
      width: 95%;
      margin: 1rem 2.5%;
      position: relative;
      padding: 0.75rem;
      background: rgba(248, 250, 252, 0.8);
      border-left: 3px solid #4f46e5;
      border-radius: 0.25rem;
    }

    .margin-toggle:checked + .sidenote {
      display: block;
    }
  }
</style>