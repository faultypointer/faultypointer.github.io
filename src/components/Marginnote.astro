---
interface Props {
  id?: string;
}

const { id } = Astro.props;
const noteId = id || `mn-${Math.random().toString(36).substr(2, 9)}`;
---

<label for={noteId} class="margin-toggle">⊕</label>
<input type="checkbox" id={noteId} class="margin-toggle" />
<span class="marginnote">
  <slot />
</span>

<style>
  .margin-toggle {
    display: none;
  }

  /* The symbol that appears in text on mobile */
  label.margin-toggle {
    cursor: pointer;
    color: #4f46e5;
    font-weight: bold;
    display: none;
  }

  .marginnote {
    float: right;
    clear: right;
    margin-right: -60%;
    width: 50%;
    margin-top: 0.3rem;
    margin-bottom: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    vertical-align: baseline;
    position: relative;
    color: #475569;
  }

  @media (max-width: 1024px) {
    label.margin-toggle {
      display: inline;
    }

    .marginnote {
      display: none;
      float: left;
      clear: both;
      width: 95%;
      margin: 1rem 2.5%;
      position: relative;
      padding: 0.75rem;
      background: rgba(248, 250, 252, 0.8);
      border-left: 3px solid #4f46e5;
      border-radius: 0.25rem;
    }

    .margin-toggle:checked + .marginnote {
      display: block;
    }
  }
</style>