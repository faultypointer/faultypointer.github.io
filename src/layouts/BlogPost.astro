---
// src/layouts/BlogPost.astro
import BaseLayout from "./BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  series?: {
    name: string;
    part: number;
    total?: number;
  };
}

const { title, description, date, updatedDate, tags = [], series } = Astro.props;

// Get series posts if this is part of a series
let seriesPosts: CollectionEntry<'posts'>[] = [];
if (series) {
  const allPosts = await getCollection("posts");
  seriesPosts = allPosts
    .filter((post) => post.data.series?.name === series.name)
    .sort((a, b) => (a.data.series?.part || 0) - (b.data.series?.part || 0));
}

// Calculate reading time
const content = await Astro.slots.render("default");
const wordsPerMinute = 200;
const wordCount = content.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / wordsPerMinute);

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} | The Fault In My Writings`} description={description}>
  <article class="blog-post">
    <header class="post-header">
      {series && (
        <div class="series-badge">
          Part {series.part}{series.total ? ` of ${series.total}` : ""} · {series.name}
        </div>
      )}
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="separator">·</span>
        <span>{readingTime} min read</span>
        {updatedDate && (
          <>
            <span class="separator">·</span>
            <span class="updated">Updated {updatedDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    {series && seriesPosts.length > 1 && (
      <nav class="series-navigation">
        <h3>Other parts in this series:</h3>
        <ol class="series-list">
          {seriesPosts.map((post) => (
            <li class={post.data.series?.part === series.part ? "current" : ""}>
              <a href={`/posts/${post.slug}`}>
                Part {post.data.series?.part}: {post.data.title}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(79, 70, 229, 0.15);
  }

  .series-badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    margin-bottom: 1rem;
    background: rgba(99, 102, 241, 0.08);
    color: #4f46e5;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .separator {
    color: #cbd5e1;
  }

  .updated {
    font-style: italic;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    padding: 0.25rem 0.625rem;
    background: rgba(99, 102, 241, 0.06);
    color: #4f46e5;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .tag:hover {
    background: rgba(99, 102, 241, 0.12);
  }

  .post-content {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #1e293b;
  }

  .post-content :global(h2) {
    font-size: 1.875rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .post-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-content :global(code) {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
  }

  .post-content :global(pre) {
    background: #1e293b;
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: #e2e8f0;
  }

  .post-content :global(a) {
    color: #4f46e5;
    text-decoration: underline;
    text-decoration-color: rgba(79, 70, 229, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }

  .post-content :global(a:hover) {
    text-decoration-color: #4f46e5;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid #4f46e5;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #475569;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .series-navigation {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(79, 70, 229, 0.15);
  }

  .series-navigation h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .series-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .series-list li {
    padding: 0.75rem;
    margin-bottom: 0.5rem;
    border-radius: 0.375rem;
    transition: background-color 0.15s ease;
  }

  .series-list li:hover {
    background: rgba(99, 102, 241, 0.04);
  }

  .series-list li.current {
    background: rgba(99, 102, 241, 0.08);
    font-weight: 500;
  }

  .series-list a {
    color: #312e81;
    text-decoration: none;
  }

  .series-list li.current a {
    color: #4f46e5;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .post-content {
      font-size: 1rem;
    }

    .post-content :global(h2) {
      font-size: 1.5rem;
    }

    .post-content :global(h3) {
      font-size: 1.25rem;
    }
  }
</style>