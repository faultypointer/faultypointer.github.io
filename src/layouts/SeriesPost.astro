---
// src/layouts/SeriesPost.astro
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  seriesTitle: string;
  seriesSlug: string;
  part: number;
  allParts: CollectionEntry<'series'>[];
  prevPart: CollectionEntry<'series'> | null;
  nextPart: CollectionEntry<'series'> | null;
}

const { 
  title, 
  description, 
  date, 
  updatedDate, 
  tags = [],
  seriesTitle,
  seriesSlug,
  part,
  allParts,
  prevPart,
  nextPart,
} = Astro.props;

// Helper to get part slug from id
function getPartSlug(id: string): string {
  const fileName = id.split('/')[1];
  return fileName.replace(/\.md$/, '');
}

// Calculate reading time
const content = await Astro.slots.render("default");
const wordsPerMinute = 200;
const wordCount = content.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / wordsPerMinute);

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} | ${seriesTitle}`} description={description}>
  <article class="series-post">
    <header class="post-header">
      <div class="breadcrumb">
        <a href="/series">Series</a>
        <span class="separator">/</span>
        <a href={`/series/${seriesSlug}`}>{seriesTitle}</a>
        <span class="separator">/</span>
        <span>Part {part}</span>
      </div>

      <div class="series-badge">
        Part {part} of {allParts.length} · {seriesTitle}
      </div>
      
      <h1>{title}</h1>
      
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="separator">·</span>
        <span>{readingTime} min read</span>
        {updatedDate && (
          <>
            <span class="separator">·</span>
            <span class="updated">Updated {updatedDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
          </>
        )}
      </div>
      
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <nav class="part-navigation">
      <div class="nav-buttons">
        {prevPart ? (
          <a href={`/series/${seriesSlug}/${getPartSlug(prevPart.id)}`} class="nav-button prev">
            <span class="nav-label">← Previous</span>
            <span class="nav-title">Part {prevPart.data.part}: {prevPart.data.title}</span>
          </a>
        ) : (
          <div class="nav-button disabled"></div>
        )}
        
        {nextPart ? (
          <a href={`/series/${seriesSlug}/${getPartSlug(nextPart.id)}`} class="nav-button next">
            <span class="nav-label">Next →</span>
            <span class="nav-title">Part {nextPart.data.part}: {nextPart.data.title}</span>
          </a>
        ) : (
          <div class="nav-button disabled"></div>
        )}
      </div>
    </nav>

    {allParts.length > 1 && (
      <nav class="series-toc">
        <h3>All parts in this series:</h3>
        <ol class="parts-list">
          {allParts.map((p) => (
            <li class={p.data.part === part ? "current" : ""}>
              <a href={`/series/${seriesSlug}/${getPartSlug(p.id)}`}>
                <span class="part-num">Part {p.data.part}:</span> {p.data.title}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  .series-post {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(79, 70, 229, 0.15);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #64748b;
  }

  .breadcrumb a {
    color: #4f46e5;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: #312e81;
  }

  .breadcrumb .separator {
    color: #cbd5e1;
  }

  .series-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    margin-bottom: 1.5rem;
    background: rgba(99, 102, 241, 0.08);
    color: #4f46e5;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .separator {
    color: #cbd5e1;
  }

  .updated {
    font-style: italic;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    padding: 0.25rem 0.625rem;
    background: rgba(99, 102, 241, 0.06);
    color: #4f46e5;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .tag:hover {
    background: rgba(99, 102, 241, 0.12);
  }

  .post-content {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #1e293b;
    margin-bottom: 3rem;
  }

  .post-content :global(h2) {
    font-size: 1.875rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .post-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-content :global(code) {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
  }

  .post-content :global(pre) {
    background: #1e293b;
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: #e2e8f0;
  }

  .post-content :global(a) {
    color: #4f46e5;
    text-decoration: underline;
    text-decoration-color: rgba(79, 70, 229, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }

  .post-content :global(a:hover) {
    text-decoration-color: #4f46e5;
  }

  .part-navigation {
    margin: 3rem 0;
    padding: 2rem 0;
    border-top: 1px solid rgba(79, 70, 229, 0.15);
    border-bottom: 1px solid rgba(79, 70, 229, 0.15);
  }

  .nav-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .nav-button {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(79, 70, 229, 0.15);
    background: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-button:not(.disabled):hover {
    border-color: rgba(79, 70, 229, 0.3);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.08);
    transform: translateY(-2px);
  }

  .nav-button.disabled {
    opacity: 0;
    pointer-events: none;
  }

  .nav-button.prev {
    text-align: left;
  }

  .nav-button.next {
    text-align: right;
  }

  .nav-label {
    font-size: 0.875rem;
    color: #4f46e5;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .nav-title {
    color: #1e293b;
    font-weight: 500;
    line-height: 1.3;
  }

  .series-toc {
    margin-top: 2rem;
  }

  .series-toc h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .parts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .parts-list li {
    padding: 0.75rem;
    margin-bottom: 0.5rem;
    border-radius: 0.375rem;
    transition: background-color 0.15s ease;
  }

  .parts-list li:hover {
    background: rgba(99, 102, 241, 0.04);
  }

  .parts-list li.current {
    background: rgba(99, 102, 241, 0.08);
    font-weight: 500;
  }

  .parts-list a {
    color: #312e81;
    text-decoration: none;
  }

  .parts-list li.current a {
    color: #4f46e5;
  }

  .part-num {
    font-weight: 600;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .post-content {
      font-size: 1rem;
    }

    .post-content :global(h2) {
      font-size: 1.5rem;
    }

    .post-content :global(h3) {
      font-size: 1.25rem;
    }

    .nav-buttons {
      grid-template-columns: 1fr;
    }

    .nav-button.next {
      text-align: left;
    }
  }
</style>